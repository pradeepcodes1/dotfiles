alias vi=nvim
alias dev="cd /Volumes/dev"

# Homebrew (after nix so nix takes priority)
[[ -d /opt/homebrew/bin ]] && export PATH="$PATH:/opt/homebrew/bin"

# Go binaries
export PATH="$HOME/go/bin:$PATH"

# Eza configuration - use ~/.config/eza for theme files
export EZA_CONFIG_DIR="{{ .chezmoi.homeDir }}/.config/eza"

# Eza aliases
alias ls='eza --icons -la --hyperlink'
alias lt='eza --icons --tree --hyperlink'
alias lsql='lazysql'
export EDITOR="nvim"
